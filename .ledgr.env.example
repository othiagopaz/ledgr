# Local Ledgr config template. Copy to `.ledgr.env` (git-ignored) and edit.
#
#   cp .ledgr.env.example .ledgr.env
#
# scripts/service.sh and scripts/dev.sh source .ledgr.env if it exists.

# Absolute path to your ledger file. If unset, Ledgr falls back to the bundled
# data/example.beancount so it still runs out of the box.
BEANCOUNT_FILE="/absolute/path/to/your-ledger.beancount"

# Optional port overrides (defaults shown):
# LEDGR_PORT=8420
# LEDGR_FRONTEND_PORT=5173

# Development: auto-reload the backend on Python edits (like dev.sh). Off by
# default so the background service stays stable. Frontend always hot-reloads.
# LEDGR_RELOAD=1
